{
  "script": "protocol_scripts/convergent_protocol.json",
  "providers": [
    "openai=<model_id>",
    "anthropic=<model_id>"
  ],
  "out_dir": "compare_outputs/example_run",
  "args": {
    "system": "",
    "random_seed": 7,
    "window": 8,
    "memory_every": 2,
    "memory_limit": 4,
    "memory_words": 140,
    "conclusion_every": 2,
    "conclusion_mode": "soft_steer",
    "conclusion_steer_strength": "strong",
    "conclusion_steer_injection": "conclusion_line",
    "delayed_mention_every": 0,
    "delayed_mention_item_limit": 3,
    "delayed_mention_min_nonconclusion_items": 1,
    "delayed_mention_min_kind_diversity": 2,
    "delayed_mention_diversity_repair": "on",
    "delayed_mention_mode": "observe",
    "delayed_mention_fire_prob": 0.35,
    "delayed_mention_fire_max_items": 2,
    "delayed_mention_leak_policy": "on",
    "delayed_mention_leak_threshold": 0.05,
    "adaptive_hazard_policy": "adaptive",
    "adaptive_hazard_profile": "balanced",
    "adaptive_hazard_stage_policy": "flat",
    "adaptive_hazard_embedding_guard": "off",
    "latent_convergence_every": 1,
    "semantic_judge_backend": "llm",
    "observer_provider": null,
    "observer_model": null,
    "embedding_provider": null,
    "embedding_model": null,
    "deferred_intent_every": 2,
    "deferred_intent_mode": "soft_fire",
    "deferred_intent_strategy": "trigger",
    "deferred_intent_timing": "offset",
    "deferred_intent_offset": 3,
    "deferred_intent_grace": 2,
    "deferred_intent_limit": 6,
    "deferred_intent_plan_policy": "periodic",
    "deferred_intent_plan_budget": 0,
    "deferred_intent_plan_max_new": 1,
    "deferred_intent_backend": "external",
    "deferred_intent_latent_injection": "off",
    "deferred_intent_ablation": "none",
    "temperature": 0.2,
    "max_tokens": 900,
    "probe_max_tokens": 220,
    "timeout": 120,
    "show_probes": true
  }
}
